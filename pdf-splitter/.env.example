# Copy to .env.local for development. On Vercel, add each variable in:
# Project → Settings → Environment Variables (Production + Preview).

# Supabase (Settings → API in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose in client code or public repos as a "public" env
SUPABASE_SERVICE_ROLE_KEY=

# Login password for the app
APP_PASSWORD=
